# Pokemon TCG API
NEXT_PUBLIC_POKEMON_API_KEY=your_api_key_here

# Supabase Configuration (OPCIONAL - para base de datos)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# OAuth Configuration (OPCIONAL)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id_here
NEXT_PUBLIC_DISCORD_CLIENT_ID=your_discord_client_id_here
NEXT_PUBLIC_GITHUB_CLIENT_ID=your_github_client_id_here
NEXT_PUBLIC_AUTH_REDIRECT_URL=http://localhost:3000

# Auth Strategy (local | supabase | oauth)
NEXT_PUBLIC_AUTH_STRATEGY=local

# Feature Flags
NEXT_PUBLIC_ENABLE_TRADING=false
NEXT_PUBLIC_ENABLE_RANKING=false
NEXT_PUBLIC_ENABLE_MISSIONS=false

# API Configuration
NEXT_PUBLIC_API_TIMEOUT_MS=10000
NEXT_PUBLIC_API_RETRY_ATTEMPTS=3
